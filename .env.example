# Environment configuration example for Avito Telegram Bot

# API key for LLM provider (e.g., OpenAI)
LLM_API_KEY=

# Path to store temporary files and archives
STORAGE_PATH=./storage

# Maximum number of parallel worker processes
MAX_WORKERS=4

# Maximum Hamming distance threshold for pHash uniqueness
PHASH_THRESHOLD=8

# Number of photos per listing by default
DEFAULT_PHOTOS_PER_LISTING=10

# JPEG quality range (min,max) for recompression
JPEG_QUALITY_RANGE=75,90

# Default watermark opacity percentage (8-12)
WATERMARK_OPACITY_DEFAULT=10

# Region / locale for text generation (e.g., ru_RU)
REGION_LOCALE=ru_RU
